# Task Monster root environment example
#
# This file is a central place to sketch the env surface for the whole project.
# Only some of these vars are currently used by the codebase today.
# The rest are placeholders for planned work like sms-bridge, OpenAI, and S3 backups.

########################################
# Current backend runtime
########################################

HOST=127.0.0.1
PORT=3001
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB_NAME=task-monster

########################################
# Current frontend runtime
########################################

PUBLIC_API_BASE_URL=http://127.0.0.1:3001

########################################
# Shared app metadata
# Planned / optional
########################################

NODE_ENV=development
APP_ENV=local
TASK_MONSTER_FRONTEND_URL=http://127.0.0.1:5173
TASK_MONSTER_BACKEND_URL=http://127.0.0.1:3001

########################################
# SMS bridge
# Planned / not wired yet
########################################

SMS_BRIDGE_PORT=3002
SMS_BRIDGE_BASE_URL=http://127.0.0.1:3002
SMS_BRIDGE_INTERNAL_SECRET=replace_with_a_long_random_secret

########################################
# OpenAI
# Planned / not wired yet
########################################

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=your_model_name_here

########################################
# SMS provider (Twilio-style placeholders)
# Planned / not wired yet
########################################

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15555555555
TWILIO_MESSAGING_SERVICE_SID=your_twilio_messaging_service_sid_here
TWILIO_WEBHOOK_SIGNATURE_SECRET=your_twilio_webhook_validation_secret_here

########################################
# AWS / EC2 / S3 backups
# Planned / not wired yet
########################################

AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_S3_BACKUP_BUCKET=your-task-monster-backup-bucket
AWS_S3_BACKUP_PREFIX=task-monster

BACKUP_ENABLED=false
BACKUP_CRON=0 */6 * * *
BACKUP_RETENTION_DAYS=30

########################################
# Notes
########################################
#
# Currently used by the app:
# - HOST
# - PORT
# - MONGO_URL
# - MONGO_DB_NAME
# - PUBLIC_API_BASE_URL
#
# Planned placeholders:
# - SMS bridge vars
# - OpenAI vars
# - Twilio vars
# - AWS/S3 backup vars
